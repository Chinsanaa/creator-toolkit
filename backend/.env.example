PORT=3001
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Enable Google and Apple under Supabase Dashboard → Authentication → Providers.
# Add redirect URL: http://localhost:3000/auth/callback (and your production URL).
ENABLE_SYNC_CRON=true
# In production, prefer external cron → POST /api/sync/cron (leave this false on the API service)
ENABLE_IN_PROCESS_SYNC_CRON=true
SYNC_CRON_SECRET=change-me-for-manual-cron-trigger
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Creator Toolkit <onboarding@resend.dev>
